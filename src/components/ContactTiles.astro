---
import { site } from '../data/site';
import Icon from './Icon.astro';
// Kein Kontaktformular (statische Seite, kein Backend) → direkte Kanäle als Tiles.
const tiles = [
  { kind: 'icon', icon: 'Phone', label: 'Anrufen', value: site.phone.display, href: `tel:${site.phone.tel}` },
  { kind: 'wa', label: 'WhatsApp', value: 'Direkt schreiben', href: `https://wa.me/${site.whatsapp}` },
  { kind: 'icon', icon: 'Mail', label: 'E-Mail', value: site.email, href: `mailto:${site.email}` },
];
---
<div class="grid gap-4 sm:grid-cols-3" data-reveal>
  {tiles.map((t) => (
    <a
      href={t.href}
      target={t.kind === 'wa' ? '_blank' : undefined}
      rel={t.kind === 'wa' ? 'noopener' : undefined}
      class="card group flex items-start gap-4 p-5 hover:-translate-y-0.5 hover:border-aqua/40 hover:shadow-lift"
    >
      <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-aqua-tint text-aqua-ink transition group-hover:bg-aqua group-hover:text-white">
        {t.kind === 'wa' ? (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.06 24l1.68-6.13A11.86 11.86 0 0 1 .16 11.9C.16 5.34 5.5 0 12.06 0a11.82 11.82 0 0 1 8.41 3.49 11.82 11.82 0 0 1 3.48 8.42c0 6.55-5.34 11.89-11.9 11.89a11.9 11.9 0 0 1-5.68-1.45L.06 24zM6.6 20.13c1.68 1 3.28 1.6 5.45 1.6 5.45 0 9.89-4.43 9.89-9.88a9.82 9.82 0 0 0-2.9-7 9.8 9.8 0 0 0-6.98-2.9c-5.46 0-9.9 4.44-9.9 9.89 0 2.28.67 3.99 1.79 5.78l-.99 3.62 3.64-.95zm11.39-5.55c-.07-.12-.27-.2-.57-.35-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.6.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.22 3.08.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.69.25-1.28.18-1.41z"/></svg>
        ) : (
          <Icon name={t.icon as string} size={20} />
        )}
      </span>
      <span class="min-w-0">
        <span class="block text-sm text-muted">{t.label}</span>
        <span class="mt-0.5 block break-words font-semibold text-ink group-hover:text-aqua-ink">{t.value}</span>
      </span>
    </a>
  ))}
</div>
