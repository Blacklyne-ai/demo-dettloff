---
import gallery from '../data/gallery.json';
import Icon from './Icon.astro';
const items = (gallery as Record<string, any[]>).projekte ?? [];
---
<section data-hscroll class="relative overflow-hidden py-20 sm:py-28">
  <div class="hstrip items-stretch lg:pl-[7vw] lg:pr-[22vw]" data-hstrack>
    <!-- Intro-Panel -->
    <div class="hpanel flex h-[46vh] w-[82vw] shrink-0 flex-col justify-center pr-6 sm:h-[58vh] sm:w-[54vw] lg:h-[66vh] lg:w-[34vw] lg:pl-8">
      <p class="eyebrow mb-3">Referenzen</p>
      <h2 class="font-display text-4xl font-semibold leading-[1.04] tracking-tighter sm:text-5xl">
        Echte Pools, <span class="italic text-aqua-ink">quer durch</span> Brandenburg.
      </h2>
      <p class="mt-4 max-w-sm text-lg leading-relaxed text-ink-soft">
        Jedes Projekt ist einzigartig und auf die Wünsche unserer Kunden abgestimmt –
        ziehen Sie sich durch unsere Referenzen.
      </p>
      <a href="/projekte" class="btn btn-primary mt-7 inline-flex w-fit">Alle Projekte ansehen <Icon name="ArrowRight" size={18} /></a>
      <p class="mt-6 hidden items-center gap-2 text-sm text-muted lg:flex">
        <Icon name="ArrowRight" size={16} class="text-aqua" /> Scrollen blättert weiter
      </p>
    </div>

    {items.map((im, i) => (
      <figure class="hpanel group relative h-[46vh] shrink-0 overflow-hidden rounded-3xl bg-mist shadow-lift sm:h-[58vh] lg:h-[66vh]">
        <button type="button" data-zoom data-full={im.src} data-cap={im.alt} class="block h-full cursor-zoom-in" aria-label="Projektbild vergrößern">
          <img src={im.src} alt={im.alt} loading="lazy" width={im.w} height={im.h}
               class="h-full w-auto max-w-none object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]" />
          <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-dark/30 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></span>
        </button>
        <span class="pointer-events-none absolute left-4 top-4 grid h-8 w-8 place-items-center rounded-full bg-white/85 font-display text-xs font-semibold text-aqua-ink backdrop-blur">{String(i + 1).padStart(2, '0')}</span>
      </figure>
    ))}
  </div>
</section>
