---
import gallery from '../data/gallery.json';
import Icon from './Icon.astro';
const items = ((gallery as Record<string, any[]>).projekte ?? []).slice(0, 6);
---
<section class="relative py-20 sm:py-28">
  <div class="wrap flex items-end justify-between gap-6">
    <div data-reveal>
      <p class="eyebrow mb-3">Referenzen</p>
      <h2 data-split class="max-w-xl font-display text-4xl font-semibold leading-[1.05] tracking-tighter sm:text-5xl">
        Echte Pools, <span class="italic text-aqua-ink">quer durch</span> Brandenburg.
      </h2>
    </div>
    <div class="hidden shrink-0 items-center gap-2 sm:flex" data-reveal>
      <button data-hs-prev type="button" aria-label="Zurück"
              class="grid h-11 w-11 place-items-center rounded-full border border-line bg-surface text-ink shadow-soft transition hover:border-aqua/50 hover:text-aqua-ink"><Icon name="ChevronLeft" size={20} /></button>
      <button data-hs-next type="button" aria-label="Weiter"
              class="grid h-11 w-11 place-items-center rounded-full border border-line bg-surface text-ink shadow-soft transition hover:border-aqua/50 hover:text-aqua-ink"><Icon name="ChevronRight" size={20} /></button>
    </div>
  </div>

  <!-- Seitlicher Streifen: nativ horizontal scrollbar, KEIN Vertikal-Hijack -->
  <div data-hs-strip class="hstrip mt-10 cursor-grab select-none px-5 sm:px-8">
    {items.map((im, i) => (
      <figure class="hpanel group relative h-[44vh] shrink-0 overflow-hidden rounded-3xl bg-mist shadow-lift sm:h-[56vh]">
        <button type="button" data-zoom data-full={im.src} data-cap={im.alt} class="block h-full cursor-zoom-in" aria-label="Projektbild vergrößern">
          <img src={im.src} alt={im.alt} loading="lazy" width={im.w} height={im.h}
               class="h-full w-auto max-w-none object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]" draggable="false" />
        </button>
        <span class="pointer-events-none absolute left-4 top-4 grid h-8 w-8 place-items-center rounded-full bg-white/85 font-display text-xs font-semibold text-aqua-ink backdrop-blur">{String(i + 1).padStart(2, '0')}</span>
      </figure>
    ))}
    <a href="/projekte" class="hpanel group flex h-[44vh] w-[78vw] shrink-0 flex-col items-start justify-center gap-3 rounded-3xl border border-line bg-surface p-8 shadow-soft transition hover:border-aqua/40 hover:shadow-lift sm:h-[56vh] sm:w-[26vw]">
      <span class="grid h-12 w-12 place-items-center rounded-2xl bg-aqua-tint text-aqua-ink"><Icon name="Images" size={24} /></span>
      <p class="font-display text-2xl font-semibold text-ink">Alle Projekte</p>
      <span class="inline-flex items-center gap-1.5 font-semibold text-aqua-ink">Galerie ansehen <Icon name="ArrowRight" size={18} class="transition-transform group-hover:translate-x-1" /></span>
    </a>
  </div>

  <p class="wrap mt-5 flex items-center gap-2 text-sm text-muted">
    <Icon name="ArrowRight" size={15} class="text-aqua" /> Seitlich wischen oder ziehen
  </p>
</section>

<script>
  const strip = document.querySelector('[data-hs-strip]');
  if (strip) {
    const amount = () => Math.min(strip.clientWidth * 0.8, 640);
    document.querySelector('[data-hs-prev]')?.addEventListener('click', () => strip.scrollBy({ left: -amount(), behavior: 'smooth' }));
    document.querySelector('[data-hs-next]')?.addEventListener('click', () => strip.scrollBy({ left: amount(), behavior: 'smooth' }));
    // Drag-to-scroll nur mit Maus (Touch nutzt nativen Swipe)
    let down = false, moved = false, sx = 0, sl = 0;
    strip.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse') return;
      down = true; moved = false; sx = e.clientX; sl = strip.scrollLeft;
    });
    strip.addEventListener('pointermove', (e) => {
      if (!down) return;
      if (Math.abs(e.clientX - sx) > 6) moved = true;
      strip.scrollLeft = sl - (e.clientX - sx);
    });
    window.addEventListener('pointerup', () => { down = false; strip.classList.remove('cursor-grabbing'); });
    strip.addEventListener('pointerdown', () => strip.classList.add('cursor-grabbing'), { passive: true });
    // Klick nach Drag unterdrücken (sonst öffnet die Lightbox)
    strip.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; } }, true);
  }
</script>
