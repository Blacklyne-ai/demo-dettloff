---
import Icon from './Icon.astro';
// Kompakte Scrollytelling-Bühne: EINE gepinnte Reihe (Bild links, Headline + Step rechts),
// Scroll scrubbt durch die 4 Phasen (Bild + Text faden zusammen). Kein Leerraum.
// Mobil / reduced-motion: kompakte vertikale Abfolge (kein Pin).
const phases = [
  { n: '01', title: 'Planung', text: 'Wir schauen uns Ihren Garten an und planen Form, Lage und Technik – abgestimmt auf Sie.', img: '/images/bauphase/bau-03.webp' },
  { n: '02', title: 'Aushub', text: 'Die Grube entsteht: sauber ausgehoben und vorbereitet für das Becken.', img: '/images/bauphase/bau-02.webp' },
  { n: '03', title: 'Bau', text: 'Becken, Technik und Anschlüsse – Schritt für Schritt, mit festen Qualitätsstandards.', img: '/images/bauphase/bau-01.webp' },
  { n: '04', title: 'Wasser marsch', text: 'Umrandung, Feinschliff, Befüllung – aus dem Garten wird eine Wohlfühloase.', img: '/images/projekte/projekt-05.webp' },
];
---
<section data-buildpin class="relative bg-dark text-white">
  <div class="pointer-events-none absolute right-0 top-1/3 -z-0 h-80 w-80 rounded-full bg-aqua/10 blur-[100px]"></div>

  <!-- Desktop: gepinnte, kompakte Bühne -->
  <div class="bp-stage">
    <div class="wrap flex min-h-[100svh] items-center py-24">
      <div class="grid w-full items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Bild links (Crossfade) -->
        <div class="relative aspect-[4/3] overflow-hidden rounded-3xl shadow-lift ring-1 ring-white/10">
          {phases.map((ph, i) => (
            <img data-bp-img data-i={i} src={ph.img} alt={`Bauphase: ${ph.title}`} width="1100" height="825" loading="lazy"
                 class:list={['absolute inset-0 h-full w-full object-cover transition-opacity duration-500 ease-out', i === 0 ? 'opacity-100' : 'opacity-0']} />
          ))}
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-dark/55 to-transparent"></div>
          <div class="absolute left-6 top-6 flex gap-2">
            {phases.map((_, i) => (
              <span data-bp-dot data-i={i} class:list={['h-1.5 rounded-full transition-all duration-500', i === 0 ? 'w-9 bg-aqua' : 'w-1.5 bg-white/30']}></span>
            ))}
          </div>
        </div>
        <!-- rechts: Headline + durchscrubbender Step -->
        <div>
          <p class="eyebrow mb-4 text-aqua">So entsteht Ihr Pool</p>
          <h2 class="font-display text-4xl font-bold leading-[1.04] tracking-tighter sm:text-5xl">
            Vom ersten Spatenstich zum <span class="text-aqua">ersten Sprung ins Wasser.</span>
          </h2>
          <div class="relative mt-9 min-h-[200px]">
            {phases.map((ph, i) => (
              <div data-bp-step data-i={i} class:list={['absolute inset-0 transition-all duration-500 ease-out', i === 0 ? 'opacity-100' : 'translate-y-3 opacity-0']}>
                <span class="font-display text-5xl font-bold leading-none text-aqua/70 sm:text-6xl">{ph.n}</span>
                <h3 class="mt-3 font-display text-2xl font-semibold sm:text-3xl">{ph.title}</h3>
                <p class="mt-3 max-w-md text-lg leading-relaxed text-white/70">{ph.text}</p>
              </div>
            ))}
          </div>
          <a href="/bauphase" class="btn btn-on-dark mt-8 inline-flex">Alle Einblicke in die Bauphase <Icon name="ArrowRight" size={18} /></a>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobil / reduced-motion: kompakte vertikale Abfolge -->
  <div class="bp-list wrap py-20">
    <p class="eyebrow mb-3 text-aqua">So entsteht Ihr Pool</p>
    <h2 class="font-display text-4xl font-bold leading-[1.05] tracking-tighter">Vom ersten Spatenstich zum <span class="text-aqua">ersten Sprung ins Wasser.</span></h2>
    <div class="mt-10 space-y-12">
      {phases.map((ph) => (
        <div data-reveal>
          <div class="overflow-hidden rounded-2xl shadow-lift ring-1 ring-white/10">
            <img src={ph.img} alt={`Bauphase: ${ph.title}`} loading="lazy" width="1100" height="800" class="aspect-[4/3] w-full object-cover" />
          </div>
          <div class="mt-4 flex items-baseline gap-3">
            <span class="font-display text-3xl font-bold text-aqua/70">{ph.n}</span>
            <h3 class="font-display text-2xl font-semibold">{ph.title}</h3>
          </div>
          <p class="mt-2 max-w-md text-white/70">{ph.text}</p>
        </div>
      ))}
    </div>
    <a href="/bauphase" class="btn btn-on-dark mt-10 inline-flex">Alle Einblicke in die Bauphase <Icon name="ArrowRight" size={18} /></a>
  </div>
</section>
