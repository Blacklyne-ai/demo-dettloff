---
import { nav, legalNav, site, mapsQuery } from '../data/site';
import Icon from './Icon.astro';
const year = 2026;
const contact = [
  { icon: 'Phone', label: 'Anrufen', value: site.phone.display, href: `tel:${site.phone.tel}` },
  { icon: 'Mail', label: 'Schreiben', value: site.email, href: `mailto:${site.email}` },
  { icon: 'MapPin', label: 'Besuchen', value: `${site.address.line}, ${site.address.zip} ${site.address.city}`, href: `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`, ext: true },
];
---
<footer class="footer-flow relative isolate overflow-hidden text-white">
  <!-- übergroßer Marken-Schriftzug als Bühne -->
  <span aria-hidden="true"
        class="pointer-events-none absolute -bottom-[2.5vw] left-1/2 -z-10 -translate-x-1/2 select-none whitespace-nowrap font-display text-[27vw] font-semibold leading-none tracking-tighter text-white/[0.05]">
    Dettloff
  </span>
  <!-- türkises Tiefenlicht -->
  <div class="pointer-events-none absolute -left-32 top-10 -z-10 h-96 w-96 rounded-full bg-aqua/15 blur-[100px]"></div>

  <div class="wrap relative">
    <!-- Große Schluss-CTA -->
    <div class="grid gap-10 border-b border-white/10 py-24 sm:py-28 lg:grid-cols-[1.5fr_1fr] lg:items-end">
      <div data-reveal>
        <p class="eyebrow mb-5 text-aqua">Bereit für klares Wasser?</p>
        <h2 class="font-display text-[2.7rem] font-semibold leading-[1.0] tracking-tighter sm:text-6xl md:text-[4.75rem]">
          Lassen Sie uns <span class="italic text-aqua">Ihren Pool</span> bauen.
        </h2>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row lg:flex-col lg:items-end" data-reveal style="--reveal-delay:120ms">
        <a href="/kontakt" class="btn btn-light inline-flex w-full justify-center sm:w-auto">Beratung anfragen</a>
        <a href={`tel:${site.phone.tel}`} class="btn btn-on-dark inline-flex w-full justify-center gap-2 sm:w-auto">
          <Icon name="Phone" size={18} /> {site.phone.display}
        </a>
      </div>
    </div>

    <!-- Editorial: Marke · Kontakt-Reihen · Navigation -->
    <div class="grid gap-12 py-16 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-4" data-reveal>
        <div class="inline-flex rounded-2xl bg-white p-3 shadow-soft">
          <img src="/logo-footer.png" alt={`${site.name} – ${site.claim}`} width="195" height="155" class="h-16 w-auto" />
        </div>
        <p class="mt-6 max-w-xs leading-relaxed text-white/65">
          Maßgeschneiderte Swimmingpools seit {site.founded}. Planung, Bau, Wartung und
          Pool-Abdeckungen für {site.region}.
        </p>
        <p class="mt-5 font-display text-xl italic text-white/90">„Qualität nur vom Fachmann."</p>
      </div>

      <div class="lg:col-span-5" data-reveal style="--reveal-delay:80ms">
        <h3 class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-white/40">Kontakt</h3>
        <ul class="mt-6 divide-y divide-white/10">
          {contact.map((c) => (
            <li>
              <a href={c.href} target={c.ext ? '_blank' : undefined} rel={c.ext ? 'noopener' : undefined}
                 class="group flex items-center gap-4 py-4 transition-colors hover:text-white">
                <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-white/5 text-aqua ring-1 ring-white/10 transition-colors group-hover:bg-aqua group-hover:text-white">
                  <Icon name={c.icon} size={19} />
                </span>
                <span class="min-w-0">
                  <span class="block text-[0.78rem] uppercase tracking-wider text-white/40">{c.label}</span>
                  <span class="block truncate text-[1.05rem] font-medium text-white/85 group-hover:text-white">{c.value}</span>
                </span>
                <Icon name="ArrowUpRight" size={18} class="ml-auto shrink-0 text-white/30 transition-all group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-aqua" />
              </a>
            </li>
          ))}
          <li class="flex items-center gap-4 py-4 text-white/55">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-white/5 text-aqua ring-1 ring-white/10"><Icon name="Clock" size={19} /></span>
            <span><span class="block text-[0.78rem] uppercase tracking-wider text-white/40">Erreichbarkeit</span><span class="block text-[1.05rem] font-medium">{site.availability}</span></span>
          </li>
        </ul>
      </div>

      <nav class="lg:col-span-3" aria-label="Footer-Navigation" data-reveal style="--reveal-delay:160ms">
        <h3 class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-white/40">Seiten</h3>
        <ul class="mt-6 space-y-1">
          {nav.map((item) => (
            <li>
              <a href={item.href} class="group inline-flex items-center gap-2.5 py-1.5 text-[1.05rem] text-white/70 transition-colors hover:text-white">
                <span class="h-px w-5 bg-white/20 transition-all duration-300 group-hover:w-8 group-hover:bg-aqua"></span>{item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="flex flex-col items-center justify-between gap-3 border-t border-white/10 py-7 text-sm text-white/45 sm:flex-row">
      <p>© {year} {site.name} · {site.owner}</p>
      <nav class="flex items-center gap-6" aria-label="Rechtliches">
        {legalNav.map((item) => <a href={item.href} class="transition-colors hover:text-white">{item.label}</a>)}
        <a href="#main" class="inline-flex items-center gap-1.5 transition-colors hover:text-white">Nach oben <Icon name="ChevronRight" size={14} class="-rotate-90" /></a>
      </nav>
    </div>
  </div>
</footer>
