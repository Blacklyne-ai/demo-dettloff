---
import { nav, site } from '../data/site';
import Icon from './Icon.astro';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---
<header class="site-header sticky top-0 z-50 border-b border-line/80 bg-white/80 backdrop-blur-md">
  <div class="wrap flex items-center justify-between gap-4 py-3">
    <a href="/" class="flex shrink-0 items-center" aria-label={`${site.name} – Startseite`}>
      <img src="/logo.png" alt={`${site.name} – ${site.claim}`} width="462" height="107"
           class="h-8 w-auto sm:h-9" />
    </a>

    <nav class="hidden items-center gap-0.5 lg:flex" aria-label="Hauptnavigation">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={['nav-link', isActive(item.href) ? 'text-aqua-ink' : 'text-ink-soft hover:text-ink']}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a href={`tel:${site.phone.tel}`} class="flex items-center gap-2 text-[0.95rem] font-semibold text-ink transition-colors hover:text-aqua-ink">
        <Icon name="Phone" size={17} />
        {site.phone.display}
      </a>
      <a href="/kontakt" class="btn btn-primary inline-flex">Beratung anfragen</a>
    </div>

    <button id="navToggle" type="button"
            class="-mr-1 inline-flex items-center justify-center rounded-xl p-2 text-ink transition-colors hover:bg-mist lg:hidden"
            aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobileNav">
      <span data-menu-icon="open"><Icon name="Menu" size={26} /></span>
      <span data-menu-icon="close" class="hidden"><Icon name="X" size={26} /></span>
    </button>
  </div>

  <!-- Mobile-Panel -->
  <div id="mobileNav" class="hidden border-t border-line bg-white/95 backdrop-blur lg:hidden">
    <nav class="wrap flex flex-col py-3" aria-label="Mobile Navigation">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'rounded-xl px-3 py-2.5 text-base font-medium transition-colors',
            isActive(item.href) ? 'bg-aqua-tint text-aqua-ink' : 'text-ink hover:bg-mist',
          ]}
        >
          {item.label}
        </a>
      ))}
      <div class="mt-3 flex flex-col gap-2 border-t border-line pt-3">
        <a href={`tel:${site.phone.tel}`} class="flex items-center gap-2 px-3 py-2 font-semibold text-ink">
          <Icon name="Phone" size={18} /> {site.phone.display}
        </a>
        <a href="/kontakt" class="btn btn-primary inline-flex">Beratung anfragen</a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Header-Tiefenschatten beim Scrollen
  const header = document.querySelector('.site-header');
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile-Menü öffnen/schließen (+ Icon-Wechsel)
  const btn = document.getElementById('navToggle');
  const panel = document.getElementById('mobileNav');
  const iOpen = btn?.querySelector('[data-menu-icon="open"]');
  const iClose = btn?.querySelector('[data-menu-icon="close"]');
  btn?.addEventListener('click', () => {
    const open = panel?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
    iOpen?.classList.toggle('hidden', open);
    iClose?.classList.toggle('hidden', !open);
  });
</script>
