---
import { site } from '../data/site';
import Icon from './Icon.astro';
// Glas-Badge für den Header. Zeigt ECHTE Google-Sterne, sobald site.reviews.rating > 0
// (+ optional googleProfileUrl). Bis dahin ehrlicher Trust-Badge – keine erfundenen Sterne.
interface Props { variant?: 'bar' | 'hero' }
const { variant = 'bar' } = Astro.props;
const r = site.reviews;
const hasRating = r.rating > 0;
const onDark = variant === 'hero';
const shell = onDark
  ? 'bg-white/15 text-white ring-white/25'
  : 'bg-white/65 text-ink ring-line/70';
const full = Math.round(r.rating);
---
{hasRating ? (
  <a
    href={site.googleProfileUrl || `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.name + ' ' + site.address.city)}`}
    target="_blank" rel="noopener"
    class:list={['group inline-flex items-center gap-2 rounded-pill px-3 py-1 ring-1 backdrop-blur transition-colors', shell, onDark ? 'hover:bg-white/25' : 'hover:bg-white/85']}
    aria-label={`${r.rating} von 5 Sternen bei ${r.source}, ${r.count} Bewertungen`}
  >
    <svg width="15" height="15" viewBox="0 0 48 48" aria-hidden="true"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24s.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>
    <span class="flex items-center gap-px" aria-hidden="true">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg width="13" height="13" viewBox="0 0 24 24" class:list={[i < full ? 'text-amber-400' : onDark ? 'text-white/30' : 'text-line']} fill="currentColor"><path d="M12 2l2.95 5.98 6.6.96-4.78 4.66 1.13 6.57L12 17.98 6.1 20.17l1.13-6.57L2.45 8.94l6.6-.96z"/></svg>
      ))}
    </span>
    <span class="text-[0.82rem] font-semibold">{r.rating.toFixed(1)}</span>
    <span class:list={['text-[0.82rem]', onDark ? 'text-white/75' : 'text-muted']}>· {r.count} {r.source}-Bewertungen</span>
  </a>
) : (
  <span
    class:list={['inline-flex items-center gap-2 rounded-pill px-3 py-1 ring-1 backdrop-blur', shell]}
  >
    <Icon name="Award" size={15} class={onDark ? 'text-white' : 'text-aqua-ink'} />
    <span class="text-[0.82rem] font-semibold">Seit {site.founded}</span>
    <span class:list={['text-[0.82rem]', onDark ? 'text-white/75' : 'text-muted']}>· inhabergeführter Poolbau in {site.address.region}</span>
  </span>
)}
