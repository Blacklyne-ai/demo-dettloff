---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { nav } from '../data/site';
---
<Layout title="Seite nicht gefunden">
  <section>
    <div class="wrap flex min-h-[70vh] flex-col items-center justify-center py-24 text-center">
      <p class="font-display text-7xl font-semibold text-aqua">404</p>
      <h1 class="mt-4 text-3xl font-semibold tracking-tightish sm:text-4xl">Diese Seite ist abgetaucht.</h1>
      <p class="mt-4 max-w-md text-lg text-ink-soft">
        Die gesuchte Seite gibt es nicht (mehr). Springen Sie zurück zum Beckenrand.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn btn-primary inline-flex">Zur Startseite</a>
        <a href="/projekte" class="btn btn-ghost inline-flex">Projekte ansehen <Icon name="ArrowRight" size={18} /></a>
      </div>
    </div>
  </section>
</Layout>
