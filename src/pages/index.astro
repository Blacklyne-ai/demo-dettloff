---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import HorizontalProjects from '../components/HorizontalProjects.astro';
import BuildStory from '../components/BuildStory.astro';
import ReviewBadge from '../components/ReviewBadge.astro';
import ContactTiles from '../components/ContactTiles.astro';
import MapBlock from '../components/MapBlock.astro';
import { site, copy } from '../data/site';

const phasen = [
  { icon: 'Ruler', title: 'Planung', text: 'Wir schauen uns Ihren Garten an und planen Form, Lage und Technik.' },
  { icon: 'WavesLadder', title: 'Bau', text: 'Vom Aushub bis zum Beckenrand – sorgfältig, aus einer Hand.' },
  { icon: 'Wrench', title: 'Wartung', text: 'Auch danach Ihr Ansprechpartner – für Pflege und Service.' },
];
const typen = [
  { icon: 'ShieldCheck', name: 'Rolladen', note: 'Robust & sicher' },
  { icon: 'ThermometerSun', name: 'Thermoplane', note: 'Hält die Wärme' },
  { icon: 'Layers', name: 'Lamellen', note: 'Stilvoll & langlebig' },
];
---
<Layout>
  <!-- ───────── HERO (voll, schmilzt unten in die Leinwand) ───────── -->
  <section class="relative isolate flex min-h-[100svh] items-end overflow-hidden">
    <div data-parallax class="absolute inset-x-0 top-0 -z-10 h-[118%] w-full">
      <img
        src="/images/hero/hero-still-1280.webp"
        srcset="/images/hero/hero-still-800.webp 800w, /images/hero/hero-still-1280.webp 1280w, /images/hero/hero-still.webp 1920w"
        sizes="100vw"
        alt="Türkises Wasser einer hochwertigen Pool-Anlage"
        fetchpriority="high"
        class="h-full w-full object-cover"
      />
      <!-- Cinematic Hero-Loop (Stock, lizenzfrei Mixkit), nur Desktop; Mobil/reduced-motion = Standbild -->
      <video data-hero-video data-src="/videos/hero-pool.mp4" muted loop playsinline preload="none"
             aria-hidden="true" class="absolute inset-0 h-full w-full object-cover"></video>
    </div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-dark-deep/92 via-dark/45 to-dark/15"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-dark-deep/75 via-dark/20 to-transparent"></div>
    <!-- Übergang: Foto schmilzt in die helle Leinwand -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-t from-paper to-transparent sm:h-48"></div>

    <div data-hero-content class="wrap pb-20 pt-32 sm:pb-28">
      <div data-hero class="mb-6"><ReviewBadge variant="hero" /></div>
      <h1 data-hero-split class="max-w-3xl font-display text-5xl font-bold leading-[1.0] tracking-tighter text-white [text-shadow:0_2px_24px_rgb(5_26_35/0.45)] sm:text-6xl md:text-7xl">
        Ihr eigener Pool – <em class="text-aqua">geplant, gebaut, gepflegt.</em>
      </h1>
      <p data-hero class="mt-6 max-w-xl text-lg leading-relaxed text-white [text-shadow:0_1px_2px_rgb(5_26_35/0.6),0_2px_20px_rgb(5_26_35/0.5)]">
        Maßgeschneiderte Swimmingpools seit {site.founded} – von der ersten Idee in
        Ihrem Garten bis zur fertigen Wohlfühloase.
      </p>
      <div data-hero class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href="/kontakt" class="btn btn-light inline-flex">Beratung anfragen</a>
        <a href={`tel:${site.phone.tel}`} class="btn btn-on-dark inline-flex gap-2"><Icon name="Phone" size={18} /> {site.phone.display}</a>
      </div>
    </div>
  </section>

  <!-- ───────── INTRO / Willkommen (bleeding image rechts) ───────── -->
  <section class="relative py-24 sm:py-32">
    <div class="wrap grid items-center gap-12 lg:grid-cols-[1fr_1.05fr] lg:gap-20">
      <div data-reveal>
        <p class="eyebrow mb-3">{copy.welcomeLead}</p>
        <h2 data-split class="font-display text-4xl font-semibold leading-[1.08] tracking-tighter sm:text-5xl">
          Seit {site.founded} verwirklichen wir den Traum vom eigenen Swimmingpool.
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-ink-soft">{copy.welcomeBody}</p>
        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-4">
          {[['Award', '30+ Jahre'], ['MapPin', 'Berlin · Brandenburg'], ['ShieldCheck', 'inhabergeführt']].map(([icon, label]) => (
            <span class="inline-flex items-center gap-2 font-medium text-ink"><Icon name={icon} size={18} class="text-aqua-ink" /> {label}</span>
          ))}
        </div>
      </div>
      <div data-reveal class="relative overflow-hidden rounded-3xl shadow-lift">
        <img src="/images/hero/heroB-pool-1280.webp" srcset="/images/hero/heroB-pool-800.webp 800w, /images/hero/heroB-pool-1280.webp 1280w"
             sizes="(min-width:1024px) 52vw, 100vw" width="1280" height="1018" loading="lazy" data-img
             alt="Großzügiger Pool im Garten unter blauem Himmel" class="aspect-[5/4] w-full object-cover lg:aspect-[4/3]" />
      </div>
    </div>
  </section>

  <!-- ───────── POOLBAU (woven, kein Kasten) ───────── -->
  <section class="relative py-12 sm:py-16">
    <div class="wrap">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between" data-reveal>
        <h2 class="max-w-xl font-display text-3xl font-semibold leading-[1.1] tracking-tightish sm:text-4xl">
          Von der ersten Idee bis zum <span class="italic text-aqua-ink">klaren Wasser.</span>
        </h2>
        <a href="/pools" class="inline-flex items-center gap-1.5 font-semibold text-aqua-ink hover:gap-2.5 transition-all">Mehr zum Poolbau <Icon name="ArrowRight" size={18} /></a>
      </div>
      <div class="mt-12 grid gap-px overflow-hidden rounded-3xl bg-line/60 sm:grid-cols-3" data-reveal>
        {phasen.map((p, i) => (
          <div class="bg-paper/80 p-8 backdrop-blur">
            <div class="flex items-center gap-3">
              <span class="font-display text-2xl font-semibold text-aqua/50">0{i + 1}</span>
              <span class="grid h-10 w-10 place-items-center rounded-2xl bg-aqua-tint text-aqua-ink"><Icon name={p.icon} size={20} /></span>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-ink">{p.title}</h3>
            <p class="mt-2 leading-relaxed text-ink-soft">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────── PROJEKTE: horizontaler Durchlauf ───────── -->
  <HorizontalProjects />

  <!-- ───────── BAUPHASE: Scrollytelling ───────── -->
  <BuildStory />

  <!-- ───────── POOL-ABDECKUNGEN ───────── -->
  <section class="relative py-24 sm:py-32">
    <div class="wrap grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <div class="order-2 overflow-hidden rounded-3xl shadow-lift lg:order-1" data-reveal>
        <img src="/images/abdeckungen/abdeckung-07.webp" alt="Beleuchtete Pool-Überdachung am Abend von Schwimmbadtechnik Dettloff" loading="lazy" width="1100" height="800" data-img class="aspect-[4/3] w-full object-cover" />
      </div>
      <div class="order-1 lg:order-2" data-reveal>
        <p class="eyebrow mb-3">Pool-Abdeckungen & Überdachungen</p>
        <h2 class="font-display text-4xl font-semibold leading-[1.06] tracking-tighter sm:text-5xl">
          Und dann gut geschützt – <span class="italic text-aqua-ink">bei jedem Wetter.</span>
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-ink-soft">{copy.abdeckungen}</p>
        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {typen.map((t) => (
            <div class="rounded-2xl border border-line bg-surface/70 p-4 shadow-soft backdrop-blur">
              <Icon name={t.icon} size={22} class="text-aqua-ink" />
              <p class="mt-2 font-semibold text-ink">{t.name}</p>
              <p class="text-sm text-muted">{t.note}</p>
            </div>
          ))}
        </div>
        <a href="/pool-abdeckungen" class="btn btn-primary mt-9 inline-flex">Zu den Pool-Abdeckungen <Icon name="ArrowRight" size={18} /></a>
      </div>
    </div>
  </section>

  <!-- ───────── ÜBER UNS / seit 1994 (truck bleed links) ───────── -->
  <section class="relative py-24 sm:py-32">
    <div class="wrap grid items-center gap-12 lg:grid-cols-[1.05fr_1fr] lg:gap-20">
      <div data-reveal class="relative overflow-hidden rounded-3xl shadow-lift">
        <img src="/images/truck.webp" srcset="/images/truck-600.webp 600w, /images/truck.webp 1100w" sizes="(min-width:1024px) 52vw, 100vw"
             width="1100" height="430" loading="lazy" data-img alt="Firmenfahrzeug von Schwimmbadtechnik Dettloff" class="aspect-[16/9] w-full object-cover lg:aspect-[4/3]" />
      </div>
      <div data-reveal>
        <h2 class="font-display text-4xl font-semibold leading-[1.08] tracking-tighter sm:text-5xl">
          Ein Handwerksbetrieb, der seinen <span class="italic text-aqua-ink">Namen kennt.</span>
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-ink-soft">
          Seit {site.founded} steht Schwimmbadtechnik Dettloff für Pools, die halten,
          was sie versprechen. Inhabergeführt von {site.owner}, zu Hause in
          {' '}{site.address.city} {site.address.district} – {site.seatShort}.
        </p>
        <div class="mt-7 inline-flex items-center gap-4 rounded-2xl border border-line bg-surface/70 p-5 shadow-soft backdrop-blur">
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl border-l-4 border-red bg-aqua text-white"><Icon name="Award" size={24} /></span>
          <p class="font-medium text-ink">„Qualität nur vom Fachmann" – seit {site.founded} unser Anspruch.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────── KONTAKT (ruhiger Abschluss) ───────── -->
  <section id="kontakt" class="relative py-24 sm:py-32">
    <div class="wrap">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow mb-3">Kontakt</p>
        <h2 data-split class="font-display text-4xl font-semibold leading-[1.08] tracking-tighter sm:text-5xl">
          Lassen Sie uns über Ihren Garten sprechen.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">Rufen Sie an, schreiben Sie kurz – oder kommen Sie vorbei. {site.availability}.</p>
      </div>
      <div class="mt-10 grid gap-8 lg:grid-cols-2 lg:gap-12">
        <div class="flex flex-col gap-4">
          <ContactTiles />
          <div class="card flex items-start gap-4 p-5" data-reveal>
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-aqua-tint text-aqua-ink"><Icon name="MapPin" size={20} /></span>
            <div>
              <p class="text-sm text-muted">Adresse</p>
              <p class="mt-0.5 font-semibold text-ink">{site.address.line}</p>
              <p class="text-ink-soft">{site.address.zip} {site.address.city} {site.address.district}</p>
            </div>
          </div>
        </div>
        <MapBlock />
      </div>
    </div>
  </section>
</Layout>
