---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Gallery from '../components/Gallery.astro';
import CtaBand from '../components/CtaBand.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Icon from '../components/Icon.astro';
import { copy } from '../data/site';

const typen = [
  { icon: 'ShieldCheck', name: 'Rolladenabdeckungen', text: 'Robust und sicher – die solide Abdeckung für den Alltag.' },
  { icon: 'ThermometerSun', name: 'Thermoplane', text: 'Isolierend – hält die Wärme im Wasser und den Schmutz draußen.' },
  { icon: 'Layers', name: 'Lamellenabdeckungen', text: 'Stilvoll und langlebig – ein klarer Blick auf Ihren Pool.' },
];
const vorteile = [
  'Schutz vor Schmutz', 'Weniger Wärmeverlust', 'Weniger Verdunstung',
  'Mehr Sicherheit', 'Geringerer Pflegeaufwand', 'Niedrigere Energiekosten',
];
---
<Layout title="Pool-Abdeckungen" description="Rolladenabdeckungen, Thermoplane, Lamellenabdeckungen und Überdachungen von Schwimmbadtechnik Dettloff – Schutz, Wärme und Sicherheit für Ihren Pool.">
  <PageHero
    eyebrow="Pool-Abdeckungen & Überdachungen"
    titleHtml='Weniger Pflege, mehr Wärme, <em class="italic text-aqua-ink">mehr Sicherheit.</em>'
    intro={copy.abdeckungen}
  />

  <!-- Vorteile -->
  <section class="py-20 sm:py-28">
    <div class="wrap">
      <SectionHeading split title="Warum sich eine gute Abdeckung lohnt" />
      <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-reveal>
        {vorteile.map((v) => (
          <li class="flex items-center gap-3 rounded-2xl border border-line bg-paper px-5 py-4">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-aqua text-white"><Icon name="Check" size={18} /></span>
            <span class="font-medium text-ink">{v}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Typen -->
  <section class="py-20 sm:py-28">
    <div class="wrap">
      <SectionHeading title="Drei Abdeckungen, drei Charaktere"
        intro="Ob robust, isolierend oder stilvoll – wir finden die Abdeckung, die zu Ihrem Pool passt." />
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {typen.map((t, i) => (
          <div class="card p-7" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-aqua-tint text-aqua-ink"><Icon name={t.icon} size={24} /></span>
            <h3 class="mt-5 text-xl font-semibold text-ink">{t.name}</h3>
            <p class="mt-2 leading-relaxed text-ink-soft">{t.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Überdachungen Feature -->
  <section class="py-20 sm:py-28">
    <div class="wrap grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="overflow-hidden rounded-3xl shadow-lift" data-reveal>
        <img src="/images/abdeckungen/abdeckung-07.webp" alt="Beleuchtete Pool-Überdachung am Abend von Schwimmbadtechnik Dettloff"
             loading="lazy" width="1100" height="800" data-img class="aspect-[4/3] w-full object-cover" />
      </div>
      <div data-reveal style="--reveal-delay:100ms">
        <p class="eyebrow mb-3">Überdachungen</p>
        <h2 class="text-3xl font-semibold tracking-tightish sm:text-4xl">Baden bei jedem Wetter.</h2>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">
          Stilvolle Überdachungen verlängern Ihre Badesaison, halten Laub und Wetter
          draußen und machen den Pool zum geschützten Rückzugsort – Tag und Nacht.
        </p>
        <a href="/projekte" class="btn btn-primary mt-7 inline-flex">Überdachungen in den Projekten <Icon name="ArrowRight" size={18} /></a>
      </div>
    </div>
  </section>

  <!-- Galerie -->
  <section class="py-20 sm:py-28">
    <div class="wrap">
      <h2 class="mb-10 max-w-2xl font-display text-3xl font-semibold tracking-tightish sm:text-4xl" data-split>
        Abdeckungen & Überdachungen aus der Praxis
      </h2>
      <Gallery set="abdeckungen" eager={3} />
    </div>
  </section>

  <CtaBand title="Welche Abdeckung passt zu Ihrem Pool?" />
</Layout>
